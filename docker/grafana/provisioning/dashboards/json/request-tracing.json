{
  "uid": "wms-request-tracing",
  "title": "WMS — Request Tracing",
  "tags": ["warehouse", "tracing"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values(service)",
        "current": { "text": "All", "value": "$__all" },
        "includeAll": true,
        "multi": true,
        "refresh": 2
      },
      {
        "name": "correlation_id",
        "type": "textbox",
        "current": { "text": "", "value": "" },
        "label": "Correlation ID"
      },
      {
        "name": "search",
        "type": "textbox",
        "current": { "text": "", "value": "" },
        "label": "Search Text"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Gateway Request Volume",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service=\"warehouse-gateway\"} |~ \"Proxying to\" [1m]))",
          "legendFormat": "Requests/min",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#6C63FF" },
          "custom": { "drawStyle": "bars", "fillOpacity": 50 }
        }
      }
    },
    {
      "id": 2,
      "title": "Gateway Responses by Status",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service=\"warehouse-gateway\"} |~ \"response 200\" [1m]))",
          "legendFormat": "200 OK",
          "refId": "A"
        },
        {
          "expr": "sum(count_over_time({service=\"warehouse-gateway\"} |~ \"response 4[0-9][0-9]\" [1m]))",
          "legendFormat": "4xx Client",
          "refId": "B"
        },
        {
          "expr": "sum(count_over_time({service=\"warehouse-gateway\"} |~ \"response 5[0-9][0-9]\" [1m]))",
          "legendFormat": "5xx Server",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 50, "stacking": { "mode": "normal" } } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "200 OK" }, "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "4xx Client" }, "properties": [{ "id": "color", "value": { "fixedColor": "#FF9830", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "5xx Server" }, "properties": [{ "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 3,
      "title": "Trace by Correlation ID",
      "description": "Enter a Correlation ID in the variable above to trace a request across services",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 7 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service=~\"$service\", correlation_id=~\"${correlation_id:pipe}\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Ascending",
        "dedupStrategy": "none"
      }
    },
    {
      "id": 4,
      "title": "Search Logs",
      "description": "Enter search text in the variable above",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 17 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service=~\"$service\"} |~ \"(?i)${search}\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "id": 5,
      "title": "HTTP Requests (All Services)",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 29 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service=~\"$service\"} |~ \"(Proxying to|Received HTTP|Processing HTTP|HTTP request)\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ],
  "schemaVersion": 39
}
