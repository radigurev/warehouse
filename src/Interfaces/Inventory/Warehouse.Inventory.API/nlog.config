<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="true"
      internalLogLevel="Info"
      internalLogFile="${basedir}/logs/nlog-internal.log">

  <extensions>
    <add assembly="NLog.Loki" />
  </extensions>

  <targets>
    <target xsi:type="Console"
            name="console"
            layout="${longdate}|${level:uppercase=true}|${logger}|${scopeproperty:CorrelationId}|${message}${onexception:inner=${newline}${exception:format=tostring}}" />

    <target xsi:type="File"
            name="file"
            fileName="${basedir}/logs/warehouse-inventory-api-${shortdate}.log"
            layout="${longdate}|${level:uppercase=true}|${logger}|${scopeproperty:CorrelationId}|${message}${onexception:inner=${newline}${exception:format=tostring}}"
            archiveEvery="Day"
            maxArchiveFiles="30" />

    <target xsi:type="loki"
            name="loki"
            batchSize="200"
            taskDelayMilliseconds="500"
            endpoint="${environment:LOKI_ENDPOINT:default=http\://localhost\:3100}"
            orderWrites="true"
            layout="${longdate}|${level:uppercase=true}|${logger}|${scopeproperty:CorrelationId}|${message}${onexception:inner=${newline}${exception:format=tostring}}">
      <label name="service" layout="warehouse-inventory-api" />
      <label name="level" layout="${level:lowercase=true}" />
      <label name="correlation_id" layout="${scopeproperty:CorrelationId}" />
    </target>
  </targets>

  <rules>
    <logger name="Microsoft.EntityFrameworkCore.*" maxlevel="Info" final="true" />
    <logger name="Microsoft.AspNetCore.Routing.*" maxlevel="Info" final="true" />
    <logger name="Microsoft.AspNetCore.Mvc.Infrastructure.*" maxlevel="Info" final="true" />
    <logger name="Microsoft.AspNetCore.StaticFiles.*" maxlevel="Info" final="true" />
    <logger name="Microsoft.AspNetCore.Hosting.Diagnostics" minlevel="Info" writeTo="console,file,loki" />
    <logger name="Microsoft.AspNetCore.*" maxlevel="Warn" final="true" />
    <logger name="*" minlevel="Info" writeTo="console,file,loki" />
  </rules>
</nlog>
